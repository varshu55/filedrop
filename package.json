{
  "name": "@dreamstick/filedrop",
  "version": "2.0.8",
  "description": "Instantly host a file on a local web server with QR code for mobile transfer",
  "main": "src/index.js",
  "bin": {
    "filedrop": "bin/filedrop.js"
  },
  "pkg": {
    "assets": [
      "node_modules/node-forge/dist/forge.min.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node ./bin/filedrop.js",
    "test": "node --test src/*.test.js",
    "build": "node scripts/build.js",
    "lint": "eslint src/"
  },
  "files": [
    "bin",
    "src"
  ],
  "keywords": [
    "cli",
    "file-transfer",
    "qr-code",
    "mdns",
    "local-network",
    "airdrop",
    "ephemeral",
    "http-server"
  ],
  "author": "dreamstick",
  "license": "MIT",
  "dependencies": {
    "archiver": "^8.0.0",
    "clipboardy": "^2.3.0",
    "mime": "^3.0.0",
    "minimist": "^1.2.8",
    "multicast-dns": "^7.2.5",
    "node-forge": "^1.4.0",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^8.57.1",
    "globals": "^17.6.0",
    "pkg": "^5.8.1"
  },
  "directories": {
    "doc": "docs",
    "man": "man",
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dreamstick9/filedrop.git"
  },
  "bugs": {
    "url": "https://github.com/Dreamstick9/filedrop/issues"
  },
  "homepage": "https://github.com/Dreamstick9/filedrop#readme"
}
